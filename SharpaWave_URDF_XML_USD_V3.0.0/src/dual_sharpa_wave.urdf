<?xml version="1.0"?>
<robot name="dual_sharpa_wave">
  <mujoco>
    <compiler meshdir="meshes" balanceinertia="true" discardvisual="false" />
  </mujoco>

  <!-- ===================== -->
  <!-- 1) COMMON FIXED ROOT  -->
  <!-- ===================== -->
  <link name="base_root">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- Small but non-zero mass/inertia for stability -->
      <mass value="0.1"/>
      <inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/>
    </inertial>
  </link>
  <!-- ===================== -->
  <!-- 1) HEAD 		     -->
  <!-- ===================== -->
  
  <!-- Dummy links: inertial only -->
  <link name="head_root_1"><inertial><origin xyz="0 0 0"/><mass value="1.0E-06"/><inertia ixx="2.0E-12" ixy="0" ixz="0" iyy="2.0E-12" iyz="0" izz="2.0E-12"/></inertial></link>
  <link name="head_root_2"><inertial><origin xyz="0 0 0"/><mass value="1.0E-06"/><inertia ixx="2.0E-12" ixy="0" ixz="0" iyy="2.0E-12" iyz="0" izz="2.0E-12"/></inertial></link>
  <link name="head_root_3"><inertial><origin xyz="0 0 0"/><mass value="1.0E-06"/><inertia ixx="2.0E-12" ixy="0" ixz="0" iyy="2.0E-12" iyz="0" izz="2.0E-12"/></inertial></link>
  <link name="head_root_4"><inertial><origin xyz="0 0 0"/><mass value="1.0E-06"/><inertia ixx="2.0E-12" ixy="0" ixz="0" iyy="2.0E-12" iyz="0" izz="2.0E-12"/></inertial></link>
  <link name="head_root_5"><inertial><origin xyz="0 0 0"/><mass value="1.0E-06"/><inertia ixx="2.0E-12" ixy="0" ixz="0" iyy="2.0E-12" iyz="0" izz="2.0E-12"/></inertial></link>
  <link name="head"><inertial><origin xyz="0 0 0"/><mass value="1.0E-06"/><inertia ixx="2.0E-12" ixy="0" ixz="0" iyy="2.0E-12" iyz="0" izz="2.0E-12"/></inertial></link>

  <!-- 3T (XYZ) -->
  <joint name="head_x_joint" type="prismatic">
    <parent link="base_root"/>
    <child  link="head_root_1"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.0" upper="2.0" effort="200" velocity="2.0"/>
    <dynamics damping="5.0"/>
  </joint>

  <joint name="head_y_joint" type="prismatic">
    <parent link="head_root_1"/>
    <child  link="head_root_2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="200" velocity="2.0"/>
    <dynamics damping="5.0"/>
  </joint>

  <joint name="head_z_joint" type="prismatic">
    <parent link="head_root_2"/>
    <child  link="head_root_3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0" upper="2.0" effort="200" velocity="2.0"/>
    <dynamics damping="5.0"/>
  </joint>

  <!-- 3R (RPY) -->
  <joint name="head_roll_joint" type="continuous">
    <parent link="head_root_3"/>
    <child  link="head_root_4"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.2"/>
  </joint>

  <joint name="head_pitch_joint" type="continuous">
    <parent link="head_root_4"/>
    <child  link="head_root_5"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.2"/>
  </joint>

  <joint name="head_yaw_joint" type="continuous">
    <parent link="head_root_5"/>
    <child  link="head"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.2"/>
  </joint>
  
  <!-- ====================================== -->
  <!-- 2) LEFT HAND: 6-DOF VIRTUAL FREE FLYER -->
  <!-- ====================================== -->

  <!-- Dummy links: inertial only -->
  <link name="left_root_1"><inertial><origin xyz="0 0 0"/><mass value="1.0E-06"/><inertia ixx="2.0E-12" ixy="0" ixz="0" iyy="2.0E-12" iyz="0" izz="2.0E-12"/></inertial></link>
  <link name="left_root_2"><inertial><origin xyz="0 0 0"/><mass value="1.0E-06"/><inertia ixx="2.0E-12" ixy="0" ixz="0" iyy="2.0E-12" iyz="0" izz="2.0E-12"/></inertial></link>
  <link name="left_root_3"><inertial><origin xyz="0 0 0"/><mass value="1.0E-06"/><inertia ixx="2.0E-12" ixy="0" ixz="0" iyy="2.0E-12" iyz="0" izz="2.0E-12"/></inertial></link>
  <link name="left_root_4"><inertial><origin xyz="0 0 0"/><mass value="1.0E-06"/><inertia ixx="2.0E-12" ixy="0" ixz="0" iyy="2.0E-12" iyz="0" izz="2.0E-12"/></inertial></link>
  <link name="left_root_5"><inertial><origin xyz="0 0 0"/><mass value="1.0E-06"/><inertia ixx="2.0E-12" ixy="0" ixz="0" iyy="2.0E-12" iyz="0" izz="2.0E-12"/></inertial></link>

  <!-- 3T (XYZ) -->
  <joint name="left_x_joint" type="prismatic">
    <parent link="base_root"/>
    <child  link="left_root_1"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.0" upper="2.0" effort="200" velocity="2.0"/>
    <dynamics damping="5.0"/>
  </joint>

  <joint name="left_y_joint" type="prismatic">
    <origin
      xyz="0 -0.15 0"
      rpy="0 0 0"
    />
    <parent link="left_root_1"/>
    <child  link="left_root_2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="200" velocity="2.0"/>
    <dynamics damping="5.0"/>
  </joint>

  <joint name="left_z_joint" type="prismatic">
    <parent link="left_root_2"/>
    <child  link="left_root_3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0" upper="2.0" effort="200" velocity="2.0"/>
    <dynamics damping="5.0"/>
  </joint>

  <!-- 3R (RPY) -->
  <joint name="left_roll_joint" type="continuous">
    <parent link="left_root_3"/>
    <child  link="left_root_4"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.2"/>
  </joint>

  <joint name="left_pitch_joint" type="continuous">
    <parent link="left_root_4"/>
    <child  link="left_root_5"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.2"/>
  </joint>

  <joint name="left_yaw_joint" type="continuous">
    <parent link="left_root_5"/>
    <child  link="left_hand_C_MC"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.2"/>
  </joint>

